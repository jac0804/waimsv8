<?php

namespace App\Http\Classes\modules\modulereport\afti;

use App\Http\Classes\builder\txtfieldClass;
use App\Http\Classes\companysetup;
use App\Http\Classes\coreFunctions;

use App\Http\Classes\Logger;
use App\Http\Classes\othersClass;

use App\Http\Classes\SBCPDF;

use Illuminate\Support\Facades\URL;

use PDF;

class qs {

	private $modulename;

	public $reportParams = ['orientation' => 'p', 'format' => 'letter', 'layoutSize' => '1000'];

	public function __construct() {
		$this->fieldClass    = new txtfieldClass;
		$this->companysetup  = new companysetup;
		$this->coreFunctions = new coreFunctions;
		$this->othersClass   = new othersClass;
		$this->logger        = new Logger;
		$this->reporter      = new SBCPDF;
	}

	public function createreportfilter($config) {

		$fields = ['radioquotation', 'print'];
		$col1   = $this->fieldClass->create($fields);
		return array('col1' => $col1);
	}

	public function reportparamsdata($config) {
		return $this->coreFunctions->opentable(
			"select
            'PDFM' as print,
            'quoteprint' as radioquotation
            "
		);
	}

	public function report_quote_query($trno) {

		/*
		 ****eto ung isang version, ung nasa baba is version ni kim- pacheck na lang kung ano tama, 3 union yan
		infotab.isvalid,head.terms,infotab.termsdetails,proforma.docno as proformainvoice,proforma.dateid as proformadate,
		infotab.leadfrom,infotab.leadto,infotab.leaddur,infotab.advised,infotab.tax,head.vattype,
		bill.addr as billaddr,bill.contact as billcontact,bill.contactno as billcontactno,
		ship.addr as shipaddr,ship.contact as shipcontact,ship.contactno as shipcontactno,
		stockinfo.rem as inforem, stockinfo.leadfrom as itemleadfrom,stockinfo.leadto as itemleadto,
		stockinfo.leaddur as itemleaddur,head.industry,cust.tin,head.yourref,cust.addr as clientaddr,
		proforma.docno as proinvoice,proforma.dateid as prodate,

		 */

		$query = "select cust.tel,cust.email,head.docno,head.trno, head.clientname, bill.addr as address,
                    date(head.dateid) as dateid, head.rem,head.agent,head.wh,
                    item.barcode, item.itemname, stock.isamt as gross, stock.amt as netamt, stock.isqty as qty,
                    stock.uom, stock.disc, stock.ext, stock.line,item.brand,client.clientname as whname,
                    item.sizeid,m.model_name as model, brands.brand_desc,iteminfo.itemdescription, iteminfo.accessories,
                    agent.clientname as agentname,agent.tel as agtel,
                    infotab.inspo,infotab.deldate, infotab.ispartial,infotab.instructions, infotab.period,
                    infotab.isvalid,infotab.terms,infotab.termsdetails,proforma.docno as proformainvoice,proforma.dateid as proformadate,
                    infotab.tax,infotab.vattype,
                    bill.addr as billaddr,bill.contact as billcontact,bill.contactno as billcontactno,
                    ship.addr as shipaddr,ship.contact as shipcontact,ship.contactno as shipcontactno,
                    stockinfo.rem as inforem, head.industry,cust.tin,head.yourref,cust.addr as clientaddr,
                    proforma.docno as proinvoice,proforma.dateid as prodate,
                    concat(bill.addrline1,', ',bill.addrline2,', ',bill.city,', ',bill.province,', ',bill.country) as billingaddress,
                    stockinfo.leadfrom as itemleadfrom,stockinfo.leadto as itemleadto,stockinfo.leaddur as itemleaddur,
                    concat(stockinfo.leadfrom,' - ',stockinfo.leadto,' , ',stockinfo.leaddur) as itemleadtime,
                    infotab.leadfrom as headleadfrom,infotab.leadto as headleadto,infotab.leaddur as stockleaddur,infotab.advised,
                    concat(infotab.leadfrom,' - ',infotab.leadto,' , ',infotab.leaddur) as headleadtime
                    from qshead as head left join qsstock as stock on stock.trno=head.trno
                    left join item on item.itemid=stock.itemid
                    left join model_masterfile as m on m.model_id = item.model
                    left join client on client.client=head.wh
                    left join client as cust on cust.client = head.client
                    left join frontend_ebrands as brands on brands.brandid = item.brand
                    left join iteminfo on iteminfo.itemid = item.itemid
                    left join client as agent on agent.client= head.agent
                    left join headinfotrans as infotab on infotab.trno = head.trno
                    left join billingaddr as bill on bill.line = head.billid and bill.clientid = cust.clientid
                    left join billingaddr as ship on ship.line = head.shipid and ship.clientid = cust.clientid
                    left join stockinfotrans as stockinfo on stockinfo.line = stock.line and stockinfo.trno = stock.trno
                    left join proformainv as proforma on proforma.trno = head.trno
                    where head.doc='QS' and head.trno='$trno'
                    union all
                    select cust.tel,cust.email,head.docno,head.trno, head.clientname, bill.addr as address,
                    date(head.dateid) as dateid, head.rem,head.agent,head.wh,
                    item.barcode, item.itemname, stock.isamt as gross, stock.amt as netamt, stock.isqty as qty,
                    stock.uom, stock.disc, stock.ext, stock.line,item.brand,client.clientname as whname,
                    item.sizeid,m.model_name as model, brands.brand_desc,iteminfo.itemdescription, iteminfo.accessories,
                    agent.clientname as agentname,agent.tel as agtel,
                    infotab.inspo,infotab.deldate, infotab.ispartial,infotab.instructions, infotab.period,
                    infotab.isvalid,infotab.terms,infotab.termsdetails,proforma.docno as proformainvoice,proforma.dateid as proformadate,
                    infotab.tax,infotab.vattype,
                    bill.addr as billaddr,bill.contact as billcontact,bill.contactno as billcontactno,
                    ship.addr as shipaddr,ship.contact as shipcontact,ship.contactno as shipcontactno,
                    stockinfo.rem as inforem, head.industry,cust.tin,head.yourref,cust.addr as clientaddr,
                    proforma.docno as proinvoice,proforma.dateid as prodate,

                    concat(bill.addrline1,', ',bill.addrline2,', ',bill.city,', ',bill.province,', ',bill.country) as billingaddress,
                    stockinfo.leadfrom as itemleadfrom,stockinfo.leadto as itemleadto,stockinfo.leaddur as itemleaddur,
                    concat(stockinfo.leadfrom,' - ',stockinfo.leadto,' , ',stockinfo.leaddur) as itemleadtime,
                    infotab.leadfrom as headleadfrom,infotab.leadto as headleadto,infotab.leaddur as stockleaddur,infotab.advised,
                    concat(infotab.leadfrom,' - ',infotab.leadto,' , ',infotab.leaddur) as headleadtime
                    from hqshead as head
                    left join hqsstock as stock on stock.trno=head.trno
                    left join item on item.itemid=stock.itemid
                    left join model_masterfile as m on m.model_id = item.model
                    left join client on client.client=head.wh
                    left join client as cust on cust.client = head.client
                    left join frontend_ebrands as brands on brands.brandid = item.brand
                    left join iteminfo on iteminfo.itemid = item.itemid
                    left join client as agent on agent.client= head.agent
                    left join headinfotrans as infotab on infotab.trno = head.trno
                    left join billingaddr as bill on bill.line = head.billid and bill.clientid = cust.clientid
                    left join billingaddr as ship on ship.line = head.shipid and ship.clientid = cust.clientid
                    left join stockinfotrans as stockinfo on stockinfo.line = stock.line and stockinfo.trno = stock.trno
                    left join proformainv as proforma on proforma.trno = head.trno
                    where head.doc='QS' and head.trno='$trno'
                union all
                select cust.tel,cust.email,head.docno,head.trno, head.clientname, bill.addr as address,
                    date(head.dateid) as dateid, head.rem,head.agent,head.wh,
                    item.barcode, item.itemname, stock.isamt as gross, stock.amt as netamt, stock.isqty as qty,
                    stock.uom, stock.disc, stock.ext, stock.line,item.brand,client.clientname as whname,
                    item.sizeid,m.model_name as model, brands.brand_desc,iteminfo.itemdescription, iteminfo.accessories,
                    agent.clientname as agentname,agent.tel as agtel,
                    infotab.inspo,infotab.deldate, infotab.ispartial,infotab.instructions, infotab.period,

                    infotab.isvalid,infotab.terms,infotab.termsdetails,proforma.docno as proformainvoice,proforma.dateid as proformadate,
                    infotab.tax,infotab.vattype,
                    bill.addr as billaddr,bill.contact as billcontact,bill.contactno as billcontactno,
                    ship.addr as shipaddr,ship.contact as shipcontact,ship.contactno as shipcontactno,
                    stockinfo.rem as inforem, head.industry,cust.tin,head.yourref,cust.addr as clientaddr,

                    proforma.docno as proinvoice,proforma.dateid as prodate ,
                    concat(bill.addrline1,', ',bill.addrline2,', ',bill.city,', ',bill.province,', ',bill.country) as billingaddress,
                    stockinfo.leadfrom as itemleadfrom,stockinfo.leadto as itemleadto,stockinfo.leaddur as itemleaddur,
                    concat(stockinfo.leadfrom,' - ',stockinfo.leadto,' , ',stockinfo.leaddur) as itemleadtime,
                    infotab.leadfrom as headleadfrom,infotab.leadto as headleadto,infotab.leaddur as stockleaddur,infotab.advised,
                    concat(infotab.leadfrom,' - ',infotab.leadto,' , ',infotab.leaddur) as headleadtime
                    from qshead as head left join qtstock as stock on stock.trno=head.trno
                    left join item on item.itemid=stock.itemid
                    left join model_masterfile as m on m.model_id = item.model
                    left join client on client.client=head.wh
                    left join client as cust on cust.client = head.client
                    left join frontend_ebrands as brands on brands.brandid = item.brand
                    left join iteminfo on iteminfo.itemid = item.itemid
                    left join client as agent on agent.client= head.agent
                    left join headinfotrans as infotab on infotab.trno = head.trno
                    left join billingaddr as bill on bill.line = head.billid and bill.clientid = cust.clientid
                    left join billingaddr as ship on ship.line = head.shipid and ship.clientid = cust.clientid
                    left join stockinfotrans as stockinfo on stockinfo.line = stock.line and stockinfo.trno = stock.trno
                    left join proformainv as proforma on proforma.trno = head.trno
                    where head.doc='QS' and head.trno='$trno'
                    union all
                    select cust.tel,cust.email,head.docno,head.trno, head.clientname, bill.addr as address,
                    date(head.dateid) as dateid, head.rem,head.agent,head.wh,
                    item.barcode, item.itemname, stock.isamt as gross, stock.amt as netamt, stock.isqty as qty,
                    stock.uom, stock.disc, stock.ext, stock.line,item.brand,client.clientname as whname,
                    item.sizeid,m.model_name as model, brands.brand_desc,iteminfo.itemdescription, iteminfo.accessories,
                    agent.clientname as agentname,agent.tel as agtel,
                    infotab.inspo,infotab.deldate, infotab.ispartial,infotab.instructions, infotab.period,

                    infotab.isvalid,infotab.terms,infotab.termsdetails,proforma. docno as proformainvoice,proforma.dateid as proformadate,
                    infotab.tax,infotab.vattype,
                    bill.addr as billaddr,bill.contact as billcontact,bill.contactno as billcontactno,
                    ship.addr as shipaddr,ship.contact as shipcontact,ship.contactno as shipcontactno,
                    stockinfo.rem as inforem, head.industry,cust.tin,head.yourref,cust.addr as clientaddr,
                    proforma.docno as proinvoice,proforma.dateid as prodate ,

                    concat(bill.addrline1,', ',bill.addrline2,', ',bill.city,', ',bill.province,', ',bill.country) as billingaddress,
                    stockinfo.leadfrom as itemleadfrom,stockinfo.leadto as itemleadto,stockinfo.leaddur as itemleaddur,
                    concat(stockinfo.leadfrom,' - ',stockinfo.leadto,' , ',stockinfo.leaddur) as itemleadtime,
                    infotab.leadfrom as headleadfrom,infotab.leadto as headleadto,infotab.leaddur as stockleaddur,infotab.advised,
                    concat(infotab.leadfrom,' - ',infotab.leadto,' , ',infotab.leaddur) as headleadtime
                    from hqshead as head
                    left join hqtstock as stock on stock.trno=head.trno
                    left join item on item.itemid=stock.itemid
                    left join model_masterfile as m on m.model_id = item.model
                    left join client on client.client=head.wh
                    left join client as cust on cust.client = head.client
                    left join frontend_ebrands as brands on brands.brandid = item.brand
                    left join iteminfo on iteminfo.itemid = item.itemid
                    left join client as agent on agent.client= head.agent
                    left join headinfotrans as infotab on infotab.trno = head.trno
                    left join billingaddr as bill on bill.line = head.billid and bill.clientid = cust.clientid
                    left join billingaddr as ship on ship.line = head.shipid and ship.clientid = cust.clientid
                    left join stockinfotrans as stockinfo on stockinfo.line = stock.line and stockinfo.trno = stock.trno
                    left join proformainv as proforma on proforma.trno = head.trno
                    where head.doc='QS' and head.trno='$trno'";

		$result = json_decode(json_encode($this->coreFunctions->opentable($query)), true);
		return $result;
	}//end fn

	public function default_quote_headerpdf($params, $data, $font) {
		$center   = $params['params']['center'];
		$username = $params['params']['user'];
		//$width = 800;
		$height = 1000;

		$qry               = "select name,address,tel,tin from center where code = '".$center."'";
		$headerdata        = $this->coreFunctions->opentable($qry);
		$current_timestamp = $this->othersClass->getCurrentTimeStamp();
		$this->modulename  = app('App\Http\Classes\modules\sales\qs')->modulename;

		//$width = PDF::pixelsToUnits($width);
		//$height = PDF::pixelsToUnits($height);
		PDF::SetTitle($this->modulename);
		PDF::SetAuthor('Solutionbase Corp.');
		PDF::SetCreator('Solutionbase Corp.');
		PDF::SetSubject($this->modulename.' Module Report');
		PDF::setPageUnit('px');
		PDF::AddPage('p', [800, 1000]);
		PDF::SetMargins(20, 20);

		$fontsize9  = "9";
		$fontsize11 = "11";
		$fontsize12 = "12";
		$fontsize13 = '13';
		$fontsize14 = "14";
		$border     = "1px solid ";

		$terms = (str_split(trim($data[0]['termsdetails']), 15));

		// SetFont(family, style, size)
		// MultiCell(width, height, txt, border, align, x, y)
		// write2DBarcode(code, type, x, y, width, height, style, align)

		PDF::Image('/images/afti/qslogo.png', '', '', 330, 80);
		PDF::MultiCell(0, 20, "\n");
		PDF::SetFont($font, 'B', 18, $border);
		PDF::MultiCell(500, 0, '', '', 'L', 0, 0, '', '', false, 0, false, false, 0);
		PDF::MultiCell(260, 0, 'QUOTATION', '', 'C', 0, 0, '', '', false, 0, false, false, 0);
		PDF::MultiCell(0, 30, "\n");

		PDF::SetFont($font, 'B', $fontsize11);
		PDF::MultiCell(400, 15, '', '', 'R', false, 0);
		PDF::MultiCell(100, 15, '', '', 'L', false, 0);
		PDF::SetFillColor(211, 211, 211);
		PDF::MultiCell(100, 15, ' '.'Quotation No.', '1', 'L', 1, 0);
		PDF::SetFont($font, '', $fontsize11);
		PDF::MultiCell(160, 15, ' '.(isset($data[0]['docno'])?$data[0]['docno']:''), $border, 'L', false);

		PDF::SetFont($font, 'B', $fontsize11);
		PDF::MultiCell(400, 15, '', '', 'R', false, 0);
		PDF::MultiCell(100, 15, '', '', 'L', false, 0);
		PDF::SetFillColor(211, 211, 211);
		PDF::MultiCell(100, 15, ' '.'Quotation Date', '1', 'L', 1, 0);
		PDF::SetFont($font, '', $fontsize11);
		PDF::MultiCell(160, 15, ' '.date("F d,Y", strtotime($data[0]['dateid'])), $border, 'L', false);

		PDF::SetFont($font, 'B', $fontsize11);
		PDF::MultiCell(400, 15, '', '', 'R', false, 0);
		PDF::MultiCell(100, 15, '', '', 'L', false, 0);
		PDF::SetFillColor(211, 211, 211);
		PDF::MultiCell(100, 15, ' '.'INQ Ref No.', '1', 'L', 1, 0);
		PDF::SetFont($font, '', $fontsize11);
		PDF::MultiCell(160, 15, ' '.(isset($data[0]['yourref'])?$data[0]['yourref']:''), $border, 'L', false);

		PDF::SetFont($font, 'B', $fontsize11);
		PDF::MultiCell(400, 15, '', '', 'R', false, 0);
		PDF::MultiCell(100, 15, '', '', 'L', false, 0);
		PDF::SetFillColor(211, 211, 211);
		PDF::MultiCell(100, 15, ' '.'Payment Terms', '1', 'L', 1, 0);
		PDF::SetFont($font, '', $fontsize11);
		PDF::MultiCell(160, 15, ' '.(isset($terms[0])?$terms[0]:''), $border, 'L', false);

		PDF::SetFont($font, '', $fontsize13);
		PDF::MultiCell(400, 15, $headerdata[0]->name, '', 'L', false, 0);
		PDF::MultiCell(100, 15, '', '', 'L', false, 0);
		PDF::SetFont($font, 'B', $fontsize11);
		PDF::SetFillColor(211, 211, 211);
		PDF::MultiCell(100, 15, ' '.'Page No.', '1', 'L', 1, 0);
		PDF::SetFont($font, '', $fontsize11);
		PDF::MultiCell(160, 15, ' '.'Page    '.PDF::PageNo().'    of    '.PDF::getAliasNbPages(), $border, 'L', false);

		PDF::SetFont($font, '', $fontsize13);
		PDF::MultiCell(400, 15, $headerdata[0]->address, '', 'L', false, 0);
		PDF::MultiCell(100, 15, '', '', 'L', false, 0);
		PDF::MultiCell(100, 15, '', '', 'L', false, 0);
		PDF::MultiCell(160, 15, '', '', 'L', false);

		PDF::MultiCell(0, 0, "\n");

		PDF::SetFont($font, '', $fontsize13);
		PDF::MultiCell(400, 15, $headerdata[0]->tel, '', 'L', false, 0);
		PDF::MultiCell(100, 15, '', '', 'L', false, 0);
		PDF::MultiCell(100, 15, '', '', 'L', false, 0);
		PDF::MultiCell(160, 15, '', '', 'L', false);

		PDF::SetFont($font, '', $fontsize13);
		PDF::MultiCell(400, 15, '', '', 'L', false, 0);
		PDF::MultiCell(100, 15, '', '', 'L', false, 0);
		PDF::MultiCell(100, 15, '', '', 'L', false, 0);
		PDF::MultiCell(160, 15, '', '', 'L', false);

		PDF::SetFont($font, '', $fontsize13);
		PDF::MultiCell(400, 15, 'VAT REG TIN: '.$headerdata[0]->tin, '', 'L', false, 0);
		PDF::MultiCell(100, 15, '', '', 'L', false, 0);
		PDF::MultiCell(100, 15, '', '', 'L', false, 0);
		PDF::MultiCell(160, 15, '', '', 'L', false);

		PDF::MultiCell(0, 0, "\n");

		PDF::SetFont($font, '', $fontsize9);
		PDF::MultiCell(360, 0, '', 'TLR', 'L', false, 0);
		PDF::MultiCell(20, 0, '', '', 'L', false, 0);
		PDF::MultiCell(110, 0, '', 'TL', 'L', false, 0);
		PDF::MultiCell(270, 0, '', 'TR', 'L', false);

		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(5, 20, '', 'L', 'L', false, 0);
		PDF::MultiCell(355, 20, (isset($data[0]['clientname'])?$data[0]['clientname']:''), 'R', 'L', false, 0);
		PDF::SetFont($font, '', $fontsize11);
		PDF::MultiCell(20, 20, '', '', 'L', false, 0);
		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(5, 20, '', 'L', 'L', false, 0);
		PDF::MultiCell(105, 20, 'Contact Name: ', '', 'L', false, 0);
		PDF::SetFont($font, '', $fontsize11);
		PDF::MultiCell(270, 20, (isset($data[0]['billcontact'])?$data[0]['billcontact']:''), 'R', 'L', false);

		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(5, 20, '', 'L', 'L', false, 0);
		PDF::MultiCell(35, 20, 'TIN: ', '', 'L', false, 0);
		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(320, 20, (isset($data[0]['tin'])?$data[0]['tin']:''), 'R', 'L', false, 0);
		PDF::SetFont($font, '', $fontsize11);
		PDF::MultiCell(20, 20, '', '', 'L', false, 0);
		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(5, 20, '', 'L', 'L', false, 0);
		PDF::MultiCell(105, 20, 'Phone: ', '', 'L', false, 0);
		PDF::SetFont($font, '', $fontsize11);
		PDF::MultiCell(270, 20, (isset($data[0]['billcontactno'])?$data[0]['billcontactno']:''), 'R', 'L', false);

		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(5, 20, '', 'L', 'L', false, 0);
		PDF::MultiCell(355, 20, (isset($data[0]['billingaddress'])?$data[0]['billingaddress']:''), 'R', 'L', false, 0);
		PDF::SetFont($font, '', $fontsize11);
		PDF::MultiCell(20, 20, '', '', 'L', false, 0);
		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(5, 20, '', 'L', 'L', false, 0);
		PDF::MultiCell(105, 20, 'Email: ', '', 'L', false, 0);
		PDF::SetFont($font, '', $fontsize11);
		PDF::MultiCell(270, 20, '', 'R', 'L', false);

		PDF::SetFont($font, '', $fontsize9);
		PDF::MultiCell(360, 20, '', 'LRB', 'L', false, 0);
		PDF::MultiCell(20, 20, '', '', 'L', false, 0);
		PDF::MultiCell(110, 20, '', 'LB', 'L', false, 0);
		PDF::MultiCell(270, 20, '', 'BR', 'L', false);

		PDF::MultiCell(0, 0, "\n");

		PDF::SetFont($font, '', $fontsize13);
		PDF::SetFillColor(211, 211, 211);
		PDF::MultiCell(50, 15, 'No.', '1', 'C', 1, 0);
		PDF::MultiCell(100, 15, 'Order Code', '1', 'C', 1, 0);
		PDF::MultiCell(90, 15, 'Mfr', '1', 'C', 1, 0);
		PDF::MultiCell(220, 15, 'Description', '1', 'C', 1, 0);
		PDF::MultiCell(90, 15, 'Quantity', '1', 'C', 1, 0);
