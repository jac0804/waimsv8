		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(140, 15, (isset($data[0]['yourref'])?$data[0]['yourref']:''), 'B', 'L', false);

		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(15, 15, '', '', 'L', false, 0);
		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(205, 15, 'Contact Name: ', '', 'L', false, 0);
		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(290, 15, (isset($data[0]['billcontact'])?$data[0]['billcontact']:''), 'B', 'C', false, 0);
		PDF::MultiCell(10, 15, '', '', 'L', false, 0);
		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(100, 15, 'TIN: ', '', 'L', false, 0);
