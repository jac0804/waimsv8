		PDF::SetFont($font, 'B', $fontsize11);
		PDF::MultiCell(10, 25, '', '', 'L', false, 0);
		PDF::MultiCell(275, 25, '', '', 'L', false);

		PDF::SetTextColor(0, 0, 0, 100);

		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(15, 25, '', '', 'L', false, 0);
		PDF::MultiCell(205, 25, 'Other instruction Collection : ', '', 'L', false, 0);
		PDF::MultiCell(300, 25, '', 'B', 'L', false, 0);
		PDF::MultiCell(280, 25, '', '', 'C', false);

		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(220, 20, 'DELIVER TO:', '', 'L', false, 0);
		PDF::MultiCell(355, 20, '', 'B', 'L', false, 0);
		PDF::SetFillColor(211, 211, 211);
		PDF::MultiCell(80, 20, 'TP', '', 'R', 1, 0);
		PDF::MultiCell(145, 20, '', '', 'C', false);

		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(220, 20, 'Company Name:', '', 'L', false, 0);
		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(355, 20, (isset($data[0]['clientname'])?$data[0]['clientname']:''), 'B', 'C', false, 0);
		PDF::SetFont($font, 'B', $fontsize12);
		PDF::SetFillColor(211, 211, 211);
		PDF::MultiCell(80, 20, 'FSA', '', 'R', 1, 0);
		PDF::MultiCell(145, 20, '', '', 'C', false);

		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(220, 20, 'Contact Name / Number / Email:', '', 'L', false, 0);
		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(355, 20, (isset($data[0]['shipcontact'])?$data[0]['shipcontact']:''), 'B', 'C', false, 0);
