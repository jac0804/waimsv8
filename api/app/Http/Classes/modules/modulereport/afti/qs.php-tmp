		PDF::MultiCell(205, 15, 'Address: ', '', 'L', false, 0);
		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(290, 15, (isset($data[0]['billaddr'])?$data[0]['billaddr']:''), 'B', 'L', false, 0);
