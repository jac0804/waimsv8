		PDF::MultiCell(0, 30, "\n");

		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(220, 15, 'Industry / Vertical', '', 'L', false, 0);
		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(290, 15, (isset($data[0]['industry'])?$data[0]['industry']:''), 'B', 'L', false, 0);
		PDF::MultiCell(10, 15, '', '', 'L', false, 0);
		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(280, 15, 'Fluke/Amprobr/Hioki Reservation', '', 'L', false);

		PDF::MultiCell(0, 30, "\n");

		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(195, 25, 'COLLECTION DETAILS', '', 'L', false, 0);
		PDF::MultiCell(25, 25, '', '', 'L', false, 0);
		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(135, 25, 'AMT', '', 'L', false, 0);
		PDF::MultiCell(30, 25, '', '', 'L', false, 0);
		PDF::MultiCell(125, 25, '  '.'CR#', '', 'L', false, 0);
		PDF::MultiCell(300, 25, '', '', 'L', false);

		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(30, 15, '', '', 'L', false, 0);
