		return PDF::Output($this->modulename.'.pdf', 'S');
	}

	public function proformaplotting_headerpdf($params, $data, $font) {
		$qslogo = URL::to('/images/afti/qslogo.png');

		$center   = $params['params']['center'];
		$username = $params['params']['user'];
		//$width = 800;
		$height = 1000;

		$qry               = "select name,address,tel,tin from center where code = '".$center."'";
		$headerdata        = $this->coreFunctions->opentable($qry);
		$current_timestamp = $this->othersClass->getCurrentTimeStamp();
		$this->modulename  = app('App\Http\Classes\modules\sales\qs')->modulename;

		//$width = PDF::pixelsToUnits($width);
		//$height = PDF::pixelsToUnits($height);
		PDF::SetTitle($this->modulename);
		PDF::SetAuthor('Solutionbase Corp.');
		PDF::SetCreator('Solutionbase Corp.');
		PDF::SetSubject($this->modulename.' Module Report');
		PDF::setPageUnit('px');
		PDF::AddPage('p', [800, 1000]);
		PDF::SetMargins(20, 20);

		$fontsize9  = "9";
		$fontsize11 = "11";
		$fontsize12 = "12";
		$fontsize13 = '13';
		$fontsize14 = "14";
		$border     = "1px solid ";

		$terms = (str_split(trim($data[0]['termsdetails']), 15));

		$address = array();
		$addrarr = 0;

		// SetFont(family, style, size)
		// MultiCell(width, height, txt, border, align, x, y)
		// write2DBarcode(code, type, x, y, width, height, style, align)

		PDF::MultiCell(0, 50, "\n");

		PDF::SetFont($font, 'B', '18');
		PDF::MultiCell(400, 20, 'ACCESS FRONTIER', '', 'L', false, 0);
		PDF::SetFont($font, 'B', $fontsize14);
		PDF::MultiCell(200, 20, 'PROFORMA INVOICE: ', '', 'L', false, 0);
		PDF::MultiCell(200, 20, (isset($data[0]['proinvoice'])?$data[0]['proinvoice']:''), '', 'L', false);

		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(400, 20, $headerdata[0]->address, '', 'L', false, 0);
		PDF::SetFont($font, '', $fontsize14);
		PDF::MultiCell(200, 20, 'Date: ', '', 'L', false, 0);
		PDF::MultiCell(200, 20, date("F d,Y", strtotime($data[0]['prodate'])), '', 'L', false);

		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(400, 20, '', '', 'L', false, 0);
		PDF::SetFont($font, '', $fontsize14);
		PDF::MultiCell(200, 20, 'PO Ref: ', '', 'L', false, 0);
		PDF::MultiCell(200, 20, (isset($data[0]['yourref'])?$data[0]['yourref']:''), '', 'L', false);

		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(400, 20, $headerdata[0]->tel, '', 'L', false, 0);
		PDF::SetFont($font, 'B', $fontsize14);
		PDF::MultiCell(200, 20, 'Payment Terms: ', '', 'L', false, 0);
		PDF::MultiCell(200, 20, (isset($terms[0])?$terms[0]:''), '', 'L', false);

		PDF::SetFont($font, '', $fontsize9);
		PDF::MultiCell(400, 20, '', '', 'L', false, 0);
		PDF::MultiCell(200, 20, '', '', 'L', false, 0);
		PDF::MultiCell(200, 20, '', '', 'L', false);

		PDF::MultiCell(0, 0, "\n");

		PDF::SetFont($font, '', $fontsize14);
		PDF::MultiCell(400, 10, 'VAT REG TIN: '.$headerdata[0]->tin, '', 'L', false, 0);
		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(400, 10, (isset($data[0]['clientname'])?$data[0]['clientname']:''), '', 'L', false);

		$address = (str_split(trim($data[0]['billingaddress']), 64));
		$addrarr = count($address)-1;

		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(400, 10, '', '', 'L', false, 0);
		PDF::MultiCell(400, 10, (isset($address[0])?$address[0]:''), '', 'L', false);

		for ($b = 1; $b <= $addrarr; $b++) {
			# (isset($arritemname[$b]) ? $arritemname[$b] : '')
			PDF::SetFont($font, '', $fontsize12);
			PDF::MultiCell(400, 10, '', '', 'L', false, 0);
			PDF::MultiCell(400, 10, (isset($address[$b])?$address[$b]:''), '', 'L', false);
		}

		PDF::MultiCell(0, 0, "\n");
		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(400, 10, '', '', 'L', false, 0);
		PDF::MultiCell(50, 10, 'Phone: ', '', 'L', false, 0);
		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(350, 10, (isset($data[0]['billcontactno'])?$data[0]['billcontactno']:''), '', 'L', false);

		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(400, 10, '', '', 'L', false, 0);
		PDF::MultiCell(100, 10, 'Contact Name: ', '', 'L', false, 0);
		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(300, 10, (isset($data[0]['billcontact'])?$data[0]['billcontact']:''), '', 'L', false);

		PDF::MultiCell(0, 0, "\n");

		PDF::SetFont($font, '', $fontsize13);
		PDF::SetFillColor(211, 211, 211);
		PDF::MultiCell(50, 15, 'No.', '1', 'C', 1, 0);
		PDF::MultiCell(100, 15, 'Order Code', '1', 'C', 1, 0);
		PDF::MultiCell(90, 15, 'Mfr', '1', 'C', 1, 0);
		PDF::MultiCell(220, 15, 'Description', '1', 'C', 1, 0);
		PDF::MultiCell(90, 15, 'Quantity', '1', 'C', 1, 0);
		PDF::MultiCell(100, 15, 'Unit Price', '1', 'C', 1, 0);
		PDF::MultiCell(110, 15, 'Line Total', '1', 'C', 1, 0);

		PDF::MultiCell(0, 0, "");
	}

	public function reportproformaplottingpdf($params, $data) {
		$companyid    = $params['params']['companyid'];
		$decimalcurr  = $this->companysetup->getdecimal('currency', $params['params']);
		$decimalqty   = $this->companysetup->getdecimal('qty', $params['params']);
		$decimalprice = $this->companysetup->getdecimal('price', $params['params']);
		$center       = $params['params']['center'];
		$username     = $params['params']['user'];
		//   $count = $page = 35;
		$count = $page = 900;

		$linetotal = 0;
		$unitprice = 0;
		$vatsales  = 0;
		$vat       = 0;
		$totalext  = 0;

		$fontsize11 = "11";
		$fontsize12 = "12";
		$fontsize13 = '13';

		$font = '';

		$this->proformaplotting_headerpdf($params, $data, $font);

		$arritemname = array();
		$countarr    = 0;

		$arrordercode = array();
		$countarrcode = 0;

		$totalctr = 0;

		PDF::MultiCell(0, 0, "");

		$newpageadd = 0;
		if (!empty($data)) {

			for ($i = 0; $i < count($data); $i++) {

				$inforem = '';
				if ($data[$i]['inforem'] == '') {
					$inforem = '';
				} else {
					$inforem = $data[$i]['inforem'];
				}
				$arritemname = (str_split(trim($data[$i]['itemdescription'].$data[$i]['accessories']).'', 37));
				$countarr    = count($arritemname)-1;

				$arrordercode = (str_split(trim($data[$i]['itemname']), 20));
				$countarrcode = count($arrordercode)-1;

				$unitprice = $data[$i]['gross']-$data[$i]['disc'];
				$linetotal = $data[$i]['qty']*$unitprice;

				if ($data[$i]['itemname'] == '') {
				} else {
					if ($newpageadd == 1) {
						$newpageadd = 0;
						$this->addrow('LRB');
					}
					PDF::SetFont($font, '', 11);
					PDF::MultiCell(50, 15, $i+1, 'LR', 'C', false, 0, '', '', true, 1);
					PDF::MultiCell(100, 15, $arrordercode[0], 'LR', 'L', false, 0, '', '', false, 1);
					PDF::MultiCell(90, 15, $data[$i]['brand_desc'], 'LR', 'L', false, 0, '', '', false, 1);
					PDF::MultiCell(220, 15, $arritemname[0], 'LR', 'L', false, 0, '', '', false, 1);
					PDF::MultiCell(90, 15, number_format($data[$i]['qty'], $decimalqty).' '.$data[$i]['uom'].' ', 'LR', 'R', false, 0, '', '', false, 1);
					if ($unitprice == 0) {
						PDF::MultiCell(100, 15, '-'.' ', 'LR', 'R', false, 0, '', '', false, 1);
					} else {
						PDF::MultiCell(100, 15, 'PHP '.number_format($unitprice, $decimalprice).' ', 'LR', 'R', false, 0, '', '', false, 1);
					}
					if ($linetotal == 0) {
						PDF::MultiCell(110, 15, '-'.' ', 'LR', 'R', false, 1, '', '', false, 1);
					} else {
						PDF::MultiCell(110, 15, 'PHP '.number_format($linetotal, $decimalprice).' ', 'LR', 'R', false, 1, '', '', false, 1);
					}
					// $pdf->MultiCell(110, 15, 'PHP ' . number_format($linetotal, $decimalprice) . ' ', 'LR', 'R', false, 1, '', '', false, 1);

					if ($countarr > $countarrcode) {
						$totalctr = $countarr;
					} else {
						$totalctr = $countarrcode;
					}

					for ($b = 1; $b <= $totalctr; $b++) {
						$border = 'LR';
						PDF::MultiCell(50, 10, '', $border, 'C', false, 0, '', '', true, 1);
						PDF::MultiCell(100, 10, (isset($arrordercode[$b])?$arrordercode[$b]:''), $border, 'C', false, 0, '', '', false, 1);
						PDF::MultiCell(90, 10, '', $border, 'L', false, 0, '', '', false, 1);
						PDF::MultiCell(220, 10, (isset($arritemname[$b])?$arritemname[$b]:''), $border, 'L', false, 0, '', '', false, 1);
						PDF::MultiCell(90, 10, '', $border, 'R', false, 0, '', '', false, 1);
						PDF::MultiCell(100, 10, '', $border, 'L', false, 0, '', '', false, 1);
						PDF::MultiCell(110, 10, '', $border, 'R', false, 1, '', '', false, 1);

						if ($inforem != '') {
							PDF::MultiCell(50, 0, '', 'LR', 'C', false, 0, '', '', true, 1);
							PDF::MultiCell(100, 0, '', 'LR', 'C', false, 0, '', '', false, 1);
							PDF::MultiCell(90, 0, '', 'LR', 'L', false, 0, '', '', false, 1);
							PDF::MultiCell(220, 0, $inforem, 'LR', 'L', false, 0, '', '', false, 1);
							PDF::MultiCell(90, 0, '', 'LR', 'R', false, 0, '', '', false, 1);
							PDF::MultiCell(100, 0, '', 'LR', 'L', false, 0, '', '', false, 1);
							PDF::MultiCell(110, 0, '', 'LR', 'R', false, 1, '', '', false, 1);
						}

						if ($data[0]['advised'] == 1) {
							$leadtime = '';
						} else {
							$leadtime = $data[$i]['itemleadtime'];

							PDF::MultiCell(50, 0, '', 'LR', 'C', false, 0, '', '', true, 1);
							PDF::MultiCell(100, 0, '', 'LR', 'C', false, 0, '', '', false, 1);
							PDF::MultiCell(90, 0, '', 'LR', 'L', false, 0, '', '', false, 1);
							PDF::MultiCell(220, 0, $leadtime, 'LR', 'L', false, 0, '', '', false, 1);
							PDF::MultiCell(90, 0, '', 'LR', 'R', false, 0, '', '', false, 1);
							PDF::MultiCell(100, 0, '', 'LR', 'L', false, 0, '', '', false, 1);
							PDF::MultiCell(110, 0, '', 'LR', 'R', false, 1, '', '', false, 1);
						}

						if (PDF::getY() >= $page) {
							$this->addrow('LRB');
							$this->proformaplotting_headerpdf($params, $data, $font);
							$this->addrow('LRB');
						}
					}
				}
				//1-w, 2-h, 3-txt, 4-border = 0, 5-align = 'J', 6-fill = 0, 7-ln = 1, 8-x = '', 9-y = '', 10-reseth = true, 11-stretch = 0, 12-ishtml = false, 13-autopadding = true, 14-maxh = 0
				$this->addrow('LR');

				if ($data[0]['vattype'] == 'VATABLE') {
					$vatsales = $vatsales+$linetotal;
				} else {
					$vatsales = 0;
					$totalext = $totalext+$linetotal;
				}

				if (PDF::getY() >= $page) {
					$this->addrow('LRB');
					$newpageadd = 1;
					$this->proformaplotting_headerpdf($params, $data, $font);
				}
			}
		}

		if ($data[0]['vattype'] == 'VATABLE') {
			$vat      = $vatsales*.12;
			$totalext = $vatsales+$vat;
		} else {
			$vat = 0;
		}

		if (PDF::getY() > 750) {
			$this->addrow('LRB');
			$newpageadd = 1;
			$this->proformaplotting_headerpdf($params, $data, $font);
		}
		do {
			$this->addrow('LR');
		} while (PDF::getY() < 750);

		PDF::SetFont($font, 'B', $fontsize12);
		//$pdf->MultiCell(150, 15, '*QUOTATION VALIDITY: ', 'T', 'L', false, 0, 20, 765);
		PDF::MultiCell(550, 15, '', 'T', 'L', false, 0, 20, PDF::getY());
		PDF::SetFont($font, 'B', $fontsize12);
		PDF::SetFillColor(211, 211, 211);
		PDF::MultiCell(100, 15, 'Vat Sales', 'TLRB', 'C', 1, 0);
		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(29, 15, 'PHP', 'TB', 'L', false, 0);
		PDF::MultiCell(81, 15, number_format($vatsales, $decimalprice), 'TBR', 'R', false);

		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(550, 15, '', '', 'L', false, 0);
		PDF::SetFont($font, 'B', $fontsize12);
		PDF::SetFillColor(211, 211, 211);
		PDF::MultiCell(100, 15, '12% VAT', 'LRB', 'C', 1, 0);
		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(29, 15, 'PHP', 'B', 'L', false, 0);
		PDF::MultiCell(81, 15, number_format($vat, $decimalprice), 'BR', 'R', false);

		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(550, 15, '', '', 'L', false, 0);
		PDF::SetFont($font, 'B', $fontsize12);
		PDF::SetFillColor(211, 211, 211);
		PDF::MultiCell(100, 15, 'VAT Exempt', 'LRB', 'C', 1, 0);
		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(29, 15, 'PHP', 'B', 'L', false, 0);
		PDF::MultiCell(81, 15, '0.00', 'BR', 'R', false);

		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(550, 15, '', '', 'L', false, 0);
		PDF::SetFont($font, 'B', $fontsize12);
		PDF::SetFillColor(211, 211, 211);
		PDF::MultiCell(100, 15, 'Zero Rated', 'LRB', 'C', 1, 0);
		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(29, 15, 'PHP', 'B', 'L', false, 0);
		PDF::MultiCell(81, 15, '0.00', 'BR', 'R', false);

		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(550, 15, '', '', 'L', false, 0);
		PDF::SetFont($font, 'B', $fontsize12);
		PDF::SetFillColor(211, 211, 211);
		PDF::MultiCell(100, 15, 'LESS: WTax', 'LRB', 'C', 1, 0);
		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(29, 15, 'PHP', 'B', 'L', false, 0);
		PDF::MultiCell(81, 15, '0.00', 'BR', 'R', false);

		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(550, 15, '', '', 'L', false, 0);
		PDF::SetFont($font, 'B', $fontsize12);
		PDF::SetFillColor(211, 211, 211);
		PDF::MultiCell(100, 15, 'Delivery Charge', 'LRB', 'C', 1, 0);
		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(29, 15, 'PHP', 'B', 'L', false, 0);
		PDF::MultiCell(81, 15, '0.00', 'BR', 'R', false);

		PDF::SetFont($font, 'B', $fontsize12);
		PDF::MultiCell(550, 15, '', '', 'L', false, 0);
		PDF::SetFont($font, 'B', $fontsize12);
		PDF::SetFillColor(211, 211, 211);
		PDF::MultiCell(100, 15, 'Amount Due:', 'LBR', 'C', 1, 0);
		PDF::SetFont($font, '', $fontsize12);
		PDF::MultiCell(29, 15, 'PHP', 'B', 'L', false, 0);
		PDF::MultiCell(81, 15, number_format($totalext, $decimalprice), 'BR', 'R', false);

		PDF::SetFont($font, 'B', $fontsize13);
		PDF::MultiCell(50, 15, '', '', 'L', false, 0);
		PDF::MultiCell(500, 15, 'Approved by: ', '', 'L', false, 0);
		PDF::MultiCell(250, 15, '', '', 'L', false);

		PDF::MultiCell(0, 0, "\n");

		PDF::SetFont($font, 'B', $fontsize13);
		PDF::MultiCell(50, 15, '', '', 'L', false, 0);
		PDF::MultiCell(250, 15, '', 'B', 'L', false, 0);
		PDF::MultiCell(500, 15, '', '', 'L', false);

		PDF::MultiCell(0, 0, "\n");

		PDF::SetFont($font, 'B', $fontsize11);
		PDF::MultiCell(50, 15, '', '', 'L', false, 0);
		PDF::MultiCell(550, 15, 'Term: In the event of default of non-payment, the customer shall pay 12% interest per annum on all accounts over due plus 25% for attorney`s fees and cost of collection. The parties hereby voluntarily submit the jurisdiction of the proper court in Makat in case of litigation.', '', 'L', false, 0);
		PDF::MultiCell(200, 15, '', '', 'L', false);

		return PDF::Output($this->modulename.'.pdf', 'S');
	}

}
