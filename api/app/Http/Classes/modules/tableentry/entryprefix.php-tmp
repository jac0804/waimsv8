		$this->coreFunctions->sbcdroptriggers('center_update');
		$this->coreFunctions->sbcdroptriggers('client_update');
		$this->coreFunctions->sbcdroptriggers('frontend_highlights_update');
		$this->coreFunctions->sbcdroptriggers('hjbstock_update_before');
		$this->coreFunctions->sbcdroptriggers('hpostock_update');
		$this->coreFunctions->sbcdroptriggers('hprstock_update');
		$this->coreFunctions->sbcdroptriggers('hprstock_update_before');
		$this->coreFunctions->sbcdroptriggers('hsostock_update');
		$this->coreFunctions->sbcdroptriggers('ITEM_update');
		$this->coreFunctions->sbcdroptriggers('itembal_update');
		$this->coreFunctions->sbcdroptriggers('johead_update');
		$this->coreFunctions->sbcdroptriggers('joservice_update');
		$this->coreFunctions->sbcdroptriggers('krhead_update');
		$this->coreFunctions->sbcdroptriggers('ladetail_update');
		$this->coreFunctions->sbcdroptriggers('lahead_update');
		$this->coreFunctions->sbcdroptriggers('lastock_update');
		$this->coreFunctions->sbcdroptriggers('pchead_update');
		$this->coreFunctions->sbcdroptriggers('pcstock_update');
		$this->coreFunctions->sbcdroptriggers('pohead_update');
		$this->coreFunctions->sbcdroptriggers('postock_update_before');
		$this->coreFunctions->sbcdroptriggers('postock_update_after');
		$this->coreFunctions->sbcdroptriggers('postock_delete');
		$this->coreFunctions->sbcdroptriggers('rrstatus_update');
		$this->coreFunctions->sbcdroptriggers('rrstatus_delete');
		$this->coreFunctions->sbcdroptriggers('sohead_update');
		$this->coreFunctions->sbcdroptriggers('sostock_update_before');
		$this->coreFunctions->sbcdroptriggers('sostock_update_after');
		$this->coreFunctions->sbcdroptriggers('sostock_delete');
		$this->coreFunctions->sbcdroptriggers('term_update');
