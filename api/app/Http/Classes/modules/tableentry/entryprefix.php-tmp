         end if;

          if OLD.pic<>NEW.pic then
           insert into useraccess_log(trno,field,oldversion,userid,dateid) values(OLD.accessid,'USERACCESS',concat('Picture - ',OLD.pic,'=>',NEW.pic),New.editby,New.editdate);
         end if;

        END";
		$this->coreFunctions->execqry($qry, 'trigger');
		//END OF useraccess TRIGGER ====================================================================================================================================

		//users TRIGGER ==========================================================================================================================================
		$qry = "create TRIGGER users_update AFTER UPDATE on users FOR EACH ROW
        BEGIN

          if OLD.username<>NEW.username then
           insert into userlog(trno,field,oldversion,userid,dateid) values(OLD.idno,'USERS',concat('UserLevels - ',OLD.username,'=>',NEW.username),New.editby,New.editdate);
         end if;

          if OLD.class<>NEW.class then
           insert into userlog(trno,field,oldversion,userid,dateid) values(OLD.idno,'USERS',concat('Class - ',OLD.class,'=>',NEW.class),New.editby,New.editdate);
         end if;

        END";
		$this->coreFunctions->execqry($qry, 'trigger');
		//  if OLD.attributes<>NEW.attributes then
		//   insert into userlog(trno,field,oldversion,userid,dateid) values(OLD.idno,'USERS',concat('Attributes - ',OLD.attributes,'=>',NEW.attributes),New.editby,New.editdate);
		// end if;
		//END OF users TRIGGER ====================================================================================================================================
	}

