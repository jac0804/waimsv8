          if OLD.body<>NEW.body then
           insert into item_log(trno,field,oldversion,userid,dateid) values(OLD.itemid,'STOCKCARD',concat('Body -
            ',OLD.body,'=>',NEW.body),New.editby,New.editdate);
         end if;

          if OLD.sizeid<>NEW.sizeid then
           insert into item_log(trno,field,oldversion,userid,dateid) values(OLD.itemid,'STOCKCARD',concat('Size -
            ',OLD.sizeid,'=>',NEW.sizeid),New.editby,New.editdate);
         end if;

          if OLD.category<>NEW.category then
           insert into item_log(trno,field,oldversion,userid,dateid) values(OLD.itemid,'STOCKCARD',concat('Category -
            ',OLD.category,'=>',NEW.category),New.editby,New.editdate);
         end if;

          if OLD.uom<>NEW.uom then
           insert into item_log(trno,field,oldversion,userid,dateid) values(OLD.itemid,'STOCKCARD',concat('Unit of Mesurement -
            ',OLD.uom,'=>',NEW.uom),New.editby,New.editdate);
         end if;

          if OLD.minimum<>NEW.minimum then
           insert into item_log(trno,field,oldversion,userid,dateid) values(OLD.itemid,'STOCKCARD',concat('Minimum -
            ',OLD.minimum,'=>',NEW.minimum),New.editby,New.editdate);
         end if;

          if OLD.maximum<>NEW.maximum then
           insert into item_log(trno,field,oldversion,userid,dateid) values(OLD.itemid,'STOCKCARD',concat('Maximum -
            ',OLD.maximum,'=>',NEW.maximum),New.editby,New.editdate);
         end if;

          if OLD.amt<>NEW.amt then
           insert into item_log(trno,field,oldversion,userid,dateid) values(OLD.itemid,'STOCKCARD',concat('Retail -
            ',OLD.amt,'=>',NEW.amt),New.editby,New.editdate);
         end if;

          if OLD.amt2<>NEW.amt2 then
           insert into item_log(trno,field,oldversion,userid,dateid) values(OLD.itemid,'STOCKCARD',concat('Wholesale -
            ',OLD.amt2,'=>',NEW.amt2),New.editby,New.editdate);
         end if;

          if OLD.famt<>NEW.famt then
           insert into item_log(trno,field,oldversion,userid,dateid) values(OLD.itemid,'STOCKCARD',concat('Atp -
            ',OLD.famt,'=>',NEW.famt),New.editby,New.editdate);
         end if;

          if OLD.amt4<>NEW.amt4 then
           insert into item_log(trno,field,oldversion,userid,dateid) values(OLD.itemid,'STOCKCARD',concat('Price 1 -
            ',OLD.amt4,'=>',NEW.amt4),New.editby,New.editdate);
         end if;

          if OLD.disc<>NEW.disc then
           insert into item_log(trno,field,oldversion,userid,dateid) values(OLD.itemid,'STOCKCARD',concat('Discount -
            ',OLD.disc,'=>',NEW.disc),New.editby,New.editdate);
         end if;

          if OLD.disc2<>NEW.disc2 then
           insert into item_log(trno,field,oldversion,userid,dateid) values(OLD.itemid,'STOCKCARD',concat('Discount 2 -
           ',OLD.disc2,'=>',NEW.disc2),New.editby,New.editdate);
         end if;

          if OLD.disc3<>NEW.disc3 then
           insert into item_log(trno,field,oldversion,userid,dateid) values(OLD.itemid,'STOCKCARD',concat('Discount 3 -
           ',OLD.disc3,'=>',NEW.disc3),New.editby,New.editdate);
         end if;

          if OLD.disc4<>NEW.disc4 then
           insert into item_log(trno,field,oldversion,userid,dateid) values(OLD.itemid,'STOCKCARD',concat('Discount 4 -
           ',OLD.disc4,'=>',NEW.disc4),New.editby,New.editdate);
         end if;

          if NEW.promostart <> '0000-00-00' AND NEW.promostart <> '0000-00-00' AND NEW.promoend <> '1900-01-01' AND NEW.promoend <> '1900-01-01' then
             if NEW.promostart <> OLD.promostart OR NEW.promoend <> OLD.promoend then
                insert into frontend_endedsale (itemid,datestart,dateend) values(OLD.itemid,OLD.promostart,left(now(),10));
             end if;
          end if;

        END";
		$this->coreFunctions->execqry($qry, 'trigger');
		//END OF ITEM TRIGGER ====================================================================================================================================

