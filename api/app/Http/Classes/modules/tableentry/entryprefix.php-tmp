         if OLD.model<>NEW.model then
           insert into item_log(trno,field,oldversion,userid,dateid) values(OLD.itemid,'STOCKCARD',concat('Model -
            ',OLD.model,'=>',NEW.model),New.editby,New.editdate);
         end if;

          if OLD.brand<>NEW.brand then
           insert into item_log(trno,field,oldversion,userid,dateid) values(OLD.itemid,'STOCKCARD',concat('Brand -
            ',OLD.brand,'=>',NEW.brand),New.editby,New.editdate);
         end if;

          if OLD.class<>NEW.class then
           insert into item_log(trno,field,oldversion,userid,dateid) values(OLD.itemid,'STOCKCARD',concat('Class -
            ',OLD.class,'=>',NEW.brand),New.editby,New.editdate);
