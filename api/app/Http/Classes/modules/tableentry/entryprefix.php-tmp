	}

	private function createtriggers() {

		//COSTING TRIGGER ==========================================================================================================================================
		$qry = "create TRIGGER costing_insert BEFORE INSERT on costing FOR EACH ROW
                BEGIN
                  declare iBal decimal(18,6);

                  if NEW.REFX<>0 then
                      update rrstatus set bal=bal - New.Served where Trno=NEW.REFX and line=NEW.LINEX;
                  end if;
                END";
		$this->coreFunctions->execqry($qry, 'trigger');

		$qry = "create TRIGGER costing_update BEFORE UPDATE on costing FOR EACH ROW
                BEGIN
                    declare iBal decimal(18,6);

                    if NEW.REFX<>0 then
                      select Bal into iBal from RRStatus where Trno=NEW.REFX and line=NEW.LINEX;
                      if ((iBal+OLD.Served)-NEW.SERVEd)>=0 then
                        update rrstatus set bal=((bal + Old.Served) - New.Served) where Trno=NEW.REFX and line=NEW.LINEX;
                      else
                        CALL No_Stock_costing;
                      end if;
                    end if;
                END";
		$this->coreFunctions->execqry($qry, 'trigger');

		$qry = "create TRIGGER costing_delete BEFORE DELETE on costing FOR EACH ROW
                BEGIN
                 if OLD.SERVED<>0 then
                   update rrstatus set bal=bal+OLD.Served where trno=OLD.refx and line=OLD.linex;
                 end if;
                END";
		$this->coreFunctions->execqry($qry, 'trigger');

		//APLEDGER TRIGGER ==========================================================================================================================================
		$qry = "create TRIGGER apledger_update BEFORE UPDATE on apledger FOR EACH ROW
            BEGIN
              if New.bal<0 then
                CALL BAL_IS_GREATER_THAN_REQUIRED_BAL;
              end if;
            END";
		$this->coreFunctions->execqry($qry, 'trigger');
		//END OF APLEDGER TRIGGER ====================================================================================================================================

		//ARLEDGER TRIGGER ==========================================================================================================================================
		$qry = "create TRIGGER arledger_update BEFORE UPDATE on arledger FOR EACH ROW
            BEGIN
              if New.bal<0 then
                CALL BAL_IS_GREATER_THAN_REQUIRED_BAL;
              end if;
            END";
		$this->coreFunctions->execqry($qry, 'trigger');
		//END OF ARLEDGER TRIGGER ====================================================================================================================================

		//CENTER TRIGGER ==========================================================================================================================================
		$qry = "create TRIGGER center_update AFTER UPDATE on center FOR EACH ROW
        BEGIN

          if OLD.code<>NEW.code then
           insert into center_log(trno,field,oldversion,userid,dateid) values(OLD.code,'CENTER',concat('Code -
           ',OLD.code,'=>',NEW.code),New.editby,New.editdate);
         end if;

          if OLD.name<>NEW.name then
           insert into center_log(trno,field,oldversion,userid,dateid) values(OLD.code,'CENTER',concat('Name -
           ',OLD.name,'=>',NEW.name),New.editby,New.editdate);
         end if;

          if OLD.address<>NEW.address then
           insert into center_log(trno,field,oldversion,userid,dateid) values(OLD.code,'CENTER',concat('Address -
           ',OLD.address,'=>',NEW.address),New.editby,New.editdate);
         end if;

          if OLD.tel<>NEW.tel then
           insert into center_log(trno,field,oldversion,userid,dateid) values(OLD.code,'CENTER',concat('Telephone# -
           ',OLD.tel,'=>',NEW.tel),New.editby,New.editdate);
         end if;

          if OLD.warehouse<>NEW.warehouse then
           insert into center_log(trno,field,oldversion,userid,dateid) values(OLD.code,'CENTER',concat('Warehouse -
           ',OLD.warehouse,'=>',NEW.warehouse),New.editby,New.editdate);
         end if;

        END";
		$this->coreFunctions->execqry($qry, 'trigger');
		//END OF CENTER TRIGGER ====================================================================================================================================

		//CLIENT TRIGGER ==========================================================================================================================================
		$qry = "create TRIGGER client_update AFTER UPDATE on client FOR EACH ROW
            BEGIN

                if OLD.client<>NEW.client then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('Code - ',OLD.client,'=>',NEW.client),New.editby,New.editdate);
                end if;

                if OLD.clientname<>NEW.clientname then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('ClientName - ',OLD.clientname,'=>',NEW.clientname),New.editby,New.editdate);
                end if;

                if OLD.addr<>NEW.addr then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('Address - ',OLD.addr,'=>',NEW.addr),New.editby,New.editdate);
                end if;

                if OLD.email<>NEW.email then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('Email - ',OLD.email,'=>',NEW.email),New.editby,New.editdate);
                end if;

                if OLD.tel<>NEW.tel then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('Telephone# - ',OLD.tel,'=>',NEW.tel),New.editby,New.editdate);
                end if;

                if OLD.tel2<>NEW.tel2 then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('Mobile - ',OLD.tel2,'=>',NEW.tel2),New.editby,New.editdate);
                end if;

                if OLD.fax<>NEW.fax then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('Fax - ',OLD.fax,'=>',NEW.fax),New.editby,New.editdate);
                end if;

                if OLD.contact<>NEW.contact then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('Contact - ',OLD.contact,'=>',NEW.contact),New.editby,New.editdate);
                end if;

                if OLD.agent<>NEW.agent then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('Agent - ',OLD.agent,'=>',NEW.agent),New.editby,New.editdate);
                end if;

                if OLD.tin<>NEW.tin then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('Tin - ',OLD.tin,'=>',NEW.tin),New.editby,New.editdate);
                end if;

                if OLD.groupid<>NEW.groupid then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('GroupId - ',OLD.groupid,'=>',NEW.groupid),New.editby,New.editdate);
                end if;

                if OLD.terms<>NEW.terms then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('Terms - ',OLD.terms,'=>',NEW.terms),New.editby,New.editdate);
                end if;

                if OLD.crlimit<>NEW.crlimit then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('CreditLimit - ',OLD.crlimit,'=>',NEW.crlimit),New.editby,New.editdate);
                end if;

                if OLD.disc<>NEW.disc then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('Discount - ',OLD.disc,'=>',NEW.disc),New.editby,New.editdate);
                end if;

                if OLD.class<>NEW.class then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('Class - ',OLD.class,'=>',NEW.class),New.editby,New.editdate);
                end if;

                if OLD.type<>NEW.type then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('Type - ',OLD.type,'=>',NEW.type),New.editby,New.editdate);
                end if;

                if OLD.rem<>NEW.rem then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('Remarks - ',OLD.rem,'=>',NEW.rem),New.editby,New.editdate);
                end if;

                if OLD.start<>NEW.start then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('StartDate - ',OLD.start,'=>',NEW.start),New.editby,New.editdate);
                end if;

                if OLD.status<>NEW.status then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('Status - ',OLD.status,'=>',NEW.status),New.editby,New.editdate);
                end if;

                if OLD.province<>NEW.province then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('Province - ',OLD.province,'=>',NEW.province),New.editby,New.editdate);
                end if;

                if OLD.region<>NEW.region then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('Region - ',OLD.region,'=>',NEW.region),New.editby,New.editdate);
                end if;

                if OLD.area<>NEW.area then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('Area - ',OLD.area,'=>',NEW.area),New.editby,New.editdate);
                end if;

                if OLD.iscustomer<>NEW.iscustomer then
                    insert into client_log(trno,field,oldversion,userid,dateid) values(OLD.clientid,'CLIENT',concat('IsCustomer - ',OLD.iscustomer,'=>',NEW.iscustomer),New.editby,New.editdate);
                end if;

            END";
		$this->coreFunctions->execqry($qry, 'trigger');
		//END OF CLIENT TRIGGER ====================================================================================================================================

		//ARLEDGER TRIGGER ==========================================================================================================================================
		$qry = "create TRIGGER frontend_highlights_update BEFORE UPDATE on frontend_highlights FOR EACH ROW
        BEGIN
          if NEW.promostart <> '0000-00-00' AND NEW.promostart <> '0000-00-00' AND NEW.promoend <> '1900-01-01' AND NEW.promoend <> '1900-01-01' then
                 if NEW.promostart <> OLD.promostart OR NEW.promoend <> OLD.promoend then
                      insert into frontend_endedsale (itemid,datestart,dateend,highlight)
                      select hitem.itemid,highlights.promostart,left(highlights.promoend,10),hitem.highid from frontend_highlightitems as hitem
                      left join frontend_highlights as highlights on highlights.highid = hitem.highid
                      where hitem.highid = OLD.highid;
                 end if;
          end if;
        END";
		$this->coreFunctions->execqry($qry, 'trigger');
		//END OF ARLEDGER TRIGGER ====================================================================================================================================

		//HPOSTOCK TRIGGER ==========================================================================================================================================
		$qry = "create TRIGGER hpostock_update BEFORE UPDATE on hpostock FOR EACH ROW
        BEGIN

          if New.qa>New.qty then
            CALL QTY_IS_GREATER_THAN_PO;
          end if;
        END";
		$this->coreFunctions->execqry($qry, 'trigger');
		//END OF HPOSTOCK TRIGGER ====================================================================================================================================

		//HPRSTOCK TRIGGER ==========================================================================================================================================
		$qry = "create TRIGGER hprstock_update_before BEFORE UPDATE on hprstock FOR EACH ROW
        BEGIN

        if OLD.tsqa<>NEW.tsqa then
             if New.tsqa>New.qty then
               CALL QTY_IS_GREATER_THAN_PO;
             end if;
          end if;

        if OLD.qa<>NEW.qa then
         if New.qa>New.qty then
            CALL QTY_IS_GREATER_THAN_PO;
          end if;
        end if;

        END";
		$this->coreFunctions->execqry($qry, 'trigger');
		//END OF HPRSTOCK TRIGGER ====================================================================================================================================

		//HSOSTOCK TRIGGER ==========================================================================================================================================
		$qry = "create TRIGGER hsostock_update BEFORE UPDATE on hsostock FOR EACH ROW
        BEGIN
         if New.QA>New.ISS then
            CALL QTY_IS_GREATER_THAN_SO;
          end if;

         if New.MRSQA>New.ISS then
            CALL QTY_IS_GREATER_THAN_SO;
          end if;
        END";
		$this->coreFunctions->execqry($qry, 'trigger');
		//END OF HSOSTOCK TRIGGER ====================================================================================================================================

		//ITEM TRIGGER ==========================================================================================================================================
		$qry = "create TRIGGER ITEM_update AFTER UPDATE on item FOR EACH ROW
        BEGIN

         if OLD.barcode<>NEW.barcode then
           insert into item_log(trno,field,oldversion,userid,dateid) values(OLD.itemid,'STOCKCARD',concat('Code -
           ',OLD.barcode,'=>',NEW.barcode),New.editby,New.editdate);
         end if;

         if OLD.itemname<>NEW.itemname then
           insert into item_log(trno,field,oldversion,userid,dateid) values(OLD.itemid,'STOCKCARD',concat('ItemName -
