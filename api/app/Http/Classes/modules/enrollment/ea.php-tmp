   FROM $this->stock as stock left join $this->tablenumas num on num.trno=stock.trno left join en_subject as sub on sub.trno=stock.subjectid left join client as i on i.clientid=stock.instructorid left join en_rooms as r on r.line=stock.roomid left join en_bldg as b on b.line=stock.bldgid where stock.trno = ? and stock.line = ?
   UNION ALL
