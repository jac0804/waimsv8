	public function loaddoclisting($config) {
		$doc    = $config['params']['doc'];
		$center = $config['params']['center'];
		$qry    = "select client.clientid,client.client,client.clientname,client.addr,
    (case when o.isnew=1 then 'true' else 'false' end) as isnew,
    (case when o.isold=1 then 'true' else 'false' end) as isold
    from client left join en_studentinfo as o on o.clientid=client.clientid
    where isstudent =1 order by concat(o.lname,', ',o.fname,' ',o.mname)";

		$data = $this->coreFunctions->opentable($qry);

		return ['data' => $data, 'status' => true, 'msg' => 'Listing successfully loaded.'];
	}

