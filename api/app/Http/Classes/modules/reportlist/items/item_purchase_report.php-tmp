		$str .= $this->reporter->begintable($layoutsize);
		$str .= $this->reporter->startrow();
		$str .= $this->reporter->col('', '400', null, false, '1px solid ', 'T', 'L', 'Century Gothic', '11', '', '', '');
		$str .= $this->reporter->col('', '200', null, false, '1px solid ', 'T', 'C', 'Century Gothic', '11', '', '', '');
		$str .= $this->reporter->col('', '220', null, false, '1px solid ', 'T', 'C', 'Century Gothic', '11', '', '', '');
		// $str .= $this->reporter->col('','200',null,false,'1px solid ','','C','Century Gothic','11','','','');
		$str .= $this->reporter->col('SUBTOTAL', '200', null, false, '1px solid ', 'T', 'R', 'Century Gothic', '11', 'B', '', '');
		$str .= $this->reporter->col('', '100', null, false, '1px solid ', 'T', 'R', 'Century Gothic', '11', '', '', '');
		$str .= $this->reporter->col(number_format($subtotal, 2), '225', null, false, '1px solid ', 'T', 'R', 'Century Gothic', '11', 'B', '', '');
		$str .= $this->reporter->col('', '85', null, false, '1px solid ', 'T', 'R', 'Century Gothic', '11', '', '', '');

		$str .= $this->reporter->endrow();
		$str .= $this->reporter->endtable();

		$str .= $this->reporter->printline();

		$str .= $this->reporter->begintable($layoutsize);
		$str .= $this->reporter->startrow();
		$str .= $this->reporter->col('', '400', null, false, '1px solid ', 'T', 'L', 'Century Gothic', '11', '', '', '');
		$str .= $this->reporter->col('', '200', null, false, '1px solid ', 'T', 'C', 'Century Gothic', '11', '', '', '');
		$str .= $this->reporter->col('', '220', null, false, '1px solid ', 'T', 'C', 'Century Gothic', '11', '', '', '');
		// $str .= $this->reporter->col('','200',null,false,'1px solid ','','C','Century Gothic','11','','','');
		$str .= $this->reporter->col('TOTAL', '200', null, false, '1px solid ', 'T', 'R', 'Century Gothic', '11', 'B', '', '');
		$str .= $this->reporter->col('', '100', null, false, '1px solid ', 'T', 'R', 'Century Gothic', '11', '', '', '');
		$str .= $this->reporter->col(number_format($amt, 2), '225', null, false, '1px solid ', 'T', 'R', 'Century Gothic', '11', 'B', '', '');
		$str .= $this->reporter->col('', '85', null, false, '1px solid ', 'T', 'R', 'Century Gothic', '11', '', '', '');
		$str .= $this->reporter->endrow();
		$str .= $this->reporter->endtable();

		$str .= $this->reporter->endtable();
		$str .= $this->reporter->endreport();

		return $str;
	}

