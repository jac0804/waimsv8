		$str .= $this->reporter->col('SUBTOTAL', '200', null, false, '1px solid ', 'T', 'R', 'Century Gothic', '11', 'B', '', '');
		$str .= $this->reporter->col('', '200', null, false, '1px solid ', 'T', 'R', 'Century Gothic', '11', '', '', '');
		$str .= $this->reporter->col(number_format($subtotal, 2), '200', null, false, '1px solid ', 'T', 'R', 'Century Gothic', '11', 'B', '', '');
		$str .= $this->reporter->col('', '80', null, false, '1px solid ', 'T', 'R', 'Century Gothic', '11', '', '', '');
		$str .= $this->reporter->endrow();

		// $str .= $this->reporter->startrow();
		// $str .= $this->reporter->col('&nbsp','',null,false,'1px dotted ','B','L','Century Gothic','10','B','','2px');
		// $str .= $this->reporter->col('&nbsp','',null,false,'1px dotted ','B','L','Century Gothic','10','B','','2px');
		// $str .= $this->reporter->col('&nbsp','',null,false,'1px dotted ','B','L','Century Gothic','10','B','','2px');
		// $str .= $this->reporter->col('&nbsp','',null,false,'1px dotted ','B','L','Century Gothic','10','B','','2px');
		// $str .= $this->reporter->col('&nbsp','',null,false,'1px dotted ','B','L','Century Gothic','10','B','','2px');
		// $str .= $this->reporter->endrow();
		return $str;
	}

}//end class