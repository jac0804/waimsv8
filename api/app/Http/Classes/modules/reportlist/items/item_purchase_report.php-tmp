		$str .= $this->reporter->col('', '400', null, false, '1px solid ', 'T', 'L', 'Century Gothic', '11', '', '', '');
		$str .= $this->reporter->col('', '200', null, false, '1px solid ', 'T', 'C', 'Century Gothic', '11', '', '', '');
