use App\Http\Classes\companysetup;
use App\Http\Classes\leftmenu;

class setleftmenu {
	public function __construct() {
		$this->companysetup = new companysetup;
		$this->leftmenu     = new leftmenu;
	}

	public function createmodule($params, $module) {
		$menu = $this->$module($params);
		if (!isset($menu[$module])) {
			return [];
		}
		$parentid    = $menu[$module]['parent'];
		$i           = 1;
		$left_menu   = '';
		$left_parent = '';
		foreach ($menu[$module]['modules'] as $key => $value) {
			if (substr($value, 0, 6) != 'parent') {
				if ($left_menu == '') {
					$left_menu = $this->leftmenu->$value($params, $parentid, $i);
				} else {
					$left_menu = $left_menu.",".$this->leftmenu->$value($params, $parentid, $i);
				}
			} else {
				$left_parent = $this->leftmenu->$value($params, $parentid, $i);
			}
			$i++;
		}
		if ($left_menu != '') {
			$left_menu = "insert into left_menu (seq,parent_id,doc,url,module,class,access) values ".$left_menu;
		}
		return [$left_parent, $left_menu];
	}//end function

	public function masterfile($params) {
		$masterfile = ['parentmasterfile', 'customer', 'supplier', 'employeemaster', 'departmentmaster'];
		if ($this->companysetup->getsystemtype($params) <> 'AMS') {
			$masterfile = ['parentmasterfile', 'customer', 'supplier', 'employeemaster', 'departmentmaster', 'stockcard', 'agent', 'warehouse', 'role'];
		}

		if ($this->companysetup->getsystemtype($params) == 'WAIMS') {
			array_push($masterfile, 'forwarder');
			if ($params['companyid'] == 6) {
				if (($key = array_search('departmentmaster', $masterfile)) !== false) {
					unset($masterfile[$key]);
				}
				if (($key = array_search('role', $masterfile)) !== false) {
					unset($masterfile[$key]);
				}
			}
		}

		if ($this->companysetup->getsystemtype($params) == 'CAIMS') {
			if (($key = array_search('role', $masterfile)) !== false) {
				unset($masterfile[$key]);
			}

			if (($key = array_search('departmentmaster', $masterfile)) !== false) {
				unset($masterfile[$key]);
			}

			if ($params['companyid'] == 8) {
				if (($key = array_search('agent', $masterfile)) !== false) {
					unset($masterfile[$key]);
				}
			}
		}

		if ($this->companysetup->getisfixasset($params)) {
			array_push($masterfile, 'facard');
		}
		return ['masterfile' => ['parent' => 1, 'modules' => $masterfile]];
	}// end function

	public function itemmaster($params) {
		switch ($params['companyid']) {
			case '6':
				$itemmaster = ['parentitemmaster', 'model', 'stockgroup', 'brand', 'clientcategories', 'project', 'compatible'];
				break;
			default:
				$itemmaster = ['parentitemmaster', 'model', 'part', 'stockgroup', 'brand', 'itemclass', 'clientcategories', 'project', 'compatible', 'itemcategory', 'billingaddr'];
				break;
		}

		if ($this->companysetup->getsystemtype($params) == 'WAIMS') {
			array_push($itemmaster, 'partrequesttype', 'checkerlocation', 'deliverytype', 'itemcategory', 'whrem');//'pallet',
		}

		return ['itemmaster' => ['parent' => 2, 'modules' => $itemmaster]];
	}//end function

	public function purchase($params) {
		switch ($params['companyid']) {
			case '2':
				$purchase = ['parentpurchase', 'po', 'rr', 'dm', 'pr', 'cd', 'cd2'];
				break;
			case '3':
				$purchase = ['parentpurchase', 'pr', 'po', 'rr', 'sn', 'dm', 'cd', 'cd2'];
				break;
			default:
				$purchase = ['parentpurchase', 'po', 'rr', 'dm'];
				break;
		}
		return ['purchase' => ['parent' => 3, 'modules' => $purchase]];
	}// end function

	public function sales($params) {
		switch ($params['companyid']) {
			case 3:
