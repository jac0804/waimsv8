				break;
			case 6:
				$sales = ['parentsales', 'sa', 'sd', 'sb', 'se', 'sc', 'sf', 'cm', 'sg', 'sh', 'si'];
				break;
			default:
				if ($this->companysetup->getiscreateversion($params)) {
					$sales = ['parentsales', 'qt', 'pa', 'so', 'sj', 'cm'];
				} else {
					$sales = ['parentsales', 'pa', 'so', 'sj', 'cm'];
				}
				break;
		}
		return ['sales' => ['parent' => 4, 'modules' => $sales]];
	}// end function

